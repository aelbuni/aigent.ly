    "db:seed:upsert": "SEED_MODE=upsert tsx scripts/seed.ts",
    "sync:threats": "tsx scripts/sync-threats.ts",
    "amplify:threats": "tsx scripts/amplify-threats.ts",
    "summarize:rules": "tsx scripts/summarize-rules.ts",
    "export:catalog": "tsx scripts/export-catalog.ts"
  },
  "dependencies": {
    "@aigently/api-client": "*",
    "@aigently/db": "*",
    "@aigently/mvp-catalog": "*",
