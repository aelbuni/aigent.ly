    "@tailwindcss/oxide-linux-x64-gnu": "4.2.4",
    "@tailwindcss/oxide-linux-x64-musl": "4.2.4",
    "@tailwindcss/oxide-darwin-arm64": "4.2.4",
    "@tailwindcss/oxide-darwin-x64": "4.2.4"
