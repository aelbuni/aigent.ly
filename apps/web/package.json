    "@anthropic-ai/sdk": "^0.96.0",
    "@auth/drizzle-adapter": "^1.11.2",
    "drizzle-orm": "^0.45.2",
    "next": "^15.5.15",
    "next-auth": "^5.0.0-beta.30",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
