# Copy to .env.local for local development (never commit secrets)

# PostgreSQL — matches docker-compose.yml at repo root (port 5433)
DATABASE_URL=postgresql://aigently:aigently@localhost:5433/aigently

# Auth.js / NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=

# GitHub OAuth App (https://github.com/settings/developers)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Public URL of the app (Auth.js)
AUTH_URL=http://localhost:3000

# Fastify domain API (server-side only — do not use NEXT_PUBLIC_* for secrets)
INTERNAL_API_URL=http://127.0.0.1:4000

# Optional absolute base for stack logo URLs (API + Next DB fallback)
STACK_LOGO_CDN_BASE=

# ── Pipeline scripts (apps/web/scripts/) ─────────────────────────────────────
# Required for: amplify:threats, summarize:rules
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional — 10x faster NVD rate limit (6.5 s → 0.65 s between requests)
# Register free at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Required for sync:threats GHSA source — a GitHub PAT with read:packages scope
# In CI this is provided automatically as GITHUB_TOKEN; locally use a personal token
# https://github.com/settings/tokens
GITHUB_TOKEN=

# ── Dev / Testing ─────────────────────────────────────────────────────────────
# Set to "true" to bypass admin auth (GitHub OAuth + role check) in local dev.
# NEVER set in production — this exposes all admin routes without authentication.
ADMIN_BYPASS=
